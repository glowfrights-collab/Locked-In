# --- Database ---
# Local dev: SQLite file, zero setup required.
# Production (Supabase): postgresql://postgres:<password>@<host>:5432/postgres?schema=public
# and set provider = "postgresql" in prisma/schema.prisma (see DEPLOYMENT.md).
DATABASE_URL="file:./dev.db"

# --- Public site URL (used to build absolute referral share links) ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Download token signing secret (HMAC) ---
# Generate with: openssl rand -hex 32
DOWNLOAD_TOKEN_SECRET="dev-only-insecure-secret-change-me"

# --- Admin dashboard ---
ADMIN_PASSWORD="change-me"
# Generate with: openssl rand -hex 32
ADMIN_COOKIE_SECRET="dev-only-insecure-secret-change-me"

# --- CPX Research offerwall (currently the active survey unlock method) ---
# Find both in the CPX Research Dashboard -> Settings.
CPX_RESEARCH_APP_ID=""
CPX_RESEARCH_SECRET_KEY=""

# --- BitLabs offerwall (built, not wired up in UnlockOptionCard yet) ---
# Find both in the BitLabs Dashboard -> Apps -> Your placement -> Integration.
BITLABS_APP_TOKEN=""
BITLABS_APP_SECRET=""
